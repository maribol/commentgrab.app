    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.5.1",
    "postcss": "^8.5.15",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vue-tsc": "^3.3.5"
